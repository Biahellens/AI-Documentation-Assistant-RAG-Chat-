# Copy to .env and fill in values

# Optional: enables real LLM answers (gpt-4o-mini)
OPENAI_API_KEY=

# Chunking
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# RAG behavior
TOP_K_RESULTS=5
MEMORY_WINDOW=6

# Paths
CHROMA_PERSIST_DIR=./chroma_db
TOKEN_LOG_FILE=./logs/token_usage.jsonl

# LLM model (used if OPENAI_API_KEY is set)
LLM_MODEL=gpt-4o-mini
